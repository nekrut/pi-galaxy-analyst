{
  "name": "@galaxyproject/loom",
  "version": "0.4.1",
  "type": "module",
  "description": "AI co-scientist for Galaxy bioinformatics, built on Pi.dev",
  "keywords": [
    "galaxy",
    "bioinformatics",
    "analysis",
    "co-scientist"
  ],
  "author": "Galaxy Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/galaxyproject/loom"
  },
  "engines": {
    "node": ">=22.19"
  },
  "files": [
    "bin/",
    "extensions/",
    "shared/",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "loom": "./bin/loom.js"
  },
  "pi": {
    "extensions": [
      "./extensions/loom"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.52",
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@earendil-works/pi-tui": "^0.78.0",
    "@sinclair/typebox": "^0.34.49",
    "better-sqlite3": "^12.9.0",
    "chokidar": "^5.0.0",
    "node-html-parser": "^7.1.0",
    "pi-mcp-adapter": "^2.4.0",
    "pi-web-access": "^0.10.6",
    "tus-js-client": "^3.1.0",
    "uuid": "^14.0.0",
    "yaml": "^2.8.2"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "precommit": "lint-staged",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "evals": "tsx evals/run.ts",
    "typecheck": "tsc --noEmit",
    "check:versions": "node scripts/check-version-lockstep.mjs",
    "smoke:pack": "node scripts/smoke-pack.mjs",
    "prepublishOnly": "npm run typecheck && npm test && npm run smoke:pack"
  },
  "lint-staged": {
    "*.{json,md,css,html,yml,yaml}": "prettier --write",
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.78.0",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "dompurify": "^3.4.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "happy-dom": "^20.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "marked": "^18.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "@mozilla/readability": "^0.6.0"
  }
}
